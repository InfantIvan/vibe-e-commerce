    <mxCell id="r-post-order"
      value="&lt;b&gt;POST /api/orders&lt;/b&gt;&lt;hr/&gt;
&lt;i&gt;Body: { customer, items[ ], shippingAddress }&lt;/i&gt;&lt;br&gt;
&lt;br&gt;
&lt;b&gt;Business Logic:&lt;/b&gt;&lt;br&gt;
&#183; Validates payload (customer + items required)&lt;br&gt;
&#183; Re-calculates prices server-side (security)&lt;br&gt;
&#183; Tax: subtotal &#215; 8%&lt;br&gt;
&#183; Shipping: FREE if subtotal &gt; $50, else $9.99&lt;br&gt;
&#183; Generates orderId: &lt;tt&gt;VBE-{timestamp}-{rand}&lt;/tt&gt;&lt;br&gt;
&#183; Estimated delivery: +7 business days&lt;br&gt;
&lt;br&gt;
Returns full order object + delivery date"
      style="rounded=1;fillColor=#ffffff;strokeColor=#c62828;strokeWidth=1.5;
             fontSize=11;align=left;verticalAlign=top;
             spacingLeft=12;spacingTop=8;spacingRight=10;html=1;whiteSpace=wrap;"
      vertex="1" parent="1">
      <mxGeometry x="948" y="652" width="464" height="236" as="geometry" />
    </mxCell>

