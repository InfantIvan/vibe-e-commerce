    <mxCell id="r-get-products"
      value="&lt;b&gt;GET /api/products&lt;/b&gt;&lt;hr/&gt;
Query: &lt;i&gt;category, search, sort&lt;/i&gt;&lt;br&gt;
&#183; Filter by category (case-insensitive)&lt;br&gt;
&#183; Substring search on name / category / desc&lt;br&gt;
&#183; Sort: price_asc | price_desc | rating | reviews&lt;br&gt;
&lt;br&gt;
Returns: &lt;b&gt;{ count, products[ ] }&lt;/b&gt;"
      style="rounded=1;fillColor=#ffffff;strokeColor=#c62828;strokeWidth=1.5;
             fontSize=11;align=left;verticalAlign=top;
             spacingLeft=10;spacingTop=6;spacingRight=8;html=1;whiteSpace=wrap;"
      vertex="1" parent="1">
      <mxGeometry x="948" y="378" width="228" height="210" as="geometry" />
    </mxCell>

    <mxCell id="r-get-cats-and-id"
      value="&lt;b&gt;GET /api/products/categories&lt;/b&gt;&lt;hr/&gt;
Returns unique category list&lt;br&gt;
Prepends &quot;All&quot; to array&lt;br&gt;
&lt;br&gt;&lt;br&gt;
&lt;b&gt;GET /api/products/:id&lt;/b&gt;&lt;hr/&gt;
Finds product by numeric ID&lt;br&gt;
Returns &lt;b&gt;404&lt;/b&gt; if not found&lt;br&gt;
Returns single product object"
      style="rounded=1;fillColor=#ffffff;strokeColor=#c62828;strokeWidth=1.5;
             fontSize=11;align=left;verticalAlign=top;
             spacingLeft=10;spacingTop=6;spacingRight=8;html=1;whiteSpace=wrap;"
      vertex="1" parent="1">
